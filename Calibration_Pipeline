def plot_drm_grid(ds1, ds2, ref_sta, ncols=5):
    """
    Grid-layout plot of differential RM for two datasets, one figure each.

    Each subplot shows dRM[i] (already differenced against ref_sta) for
    one station, mirroring the layout of plot_dtec_comparison_grid but
    without any external comparison overlays.

    Parameters
    ----------
    ds1, ds2 : dict or None
        Dataset dicts from the main loop. Required keys: 'name', 'stations',
        'time', 'dRM', 'time_origin'. Either may be None.
    ref_sta : str
        Reference station name (used only for the figure title).
    ncols : int
        Number of subplot columns in the grid.
    """

    def make_grid(ds):
        """
        Build and show the per-station dRM grid for one dataset.

        Draws one subplot per station showing its differential RM time
        series (already referenced against `ref_sta` upstream in
        `run_pipeline`). Does nothing if `ds` is None or has no stations.

        Parameters
        ----------
        ds : dict or None
            Dataset dict with keys 'name', 'stations', 'time', 'dRM'.
        """
        if ds is None:
            return

        time     = ds["time"]
        stations = ds["stations"]
        dRM      = ds["dRM"]

        n = len(stations)
        if n == 0:
            return

        nrows = int(np.ceil(n / ncols))
        fig, axes = plt.subplots(
            nrows, ncols,
            figsize=(3.6 * ncols, 2.8 * nrows),
            squeeze=False, sharex=False, sharey=False,
        )
        axes_flat = axes.flatten()

        for ax, (i, station) in zip(axes_flat, enumerate(stations)):
            ax.plot(time, dRM[i], color="tab:orange", linewidth=1)

            ax.text(0.04, 0.92, station, transform=ax.transAxes,
                    fontsize=11, va="top", ha="left")

            ax.xaxis.set_major_locator(MaxNLocator(4))
            ax.tick_params(axis="x", labelrotation=45, labelsize=9)
            ax.tick_params(axis="y", labelsize=10)

            col = i % ncols
            if col == 0:
                ax.set_ylabel(r"dRM [rad/m²]", fontsize=9)
            if i >= n - ncols:
                ax.set_xlabel(r"Time [hours]", fontsize=9)

        for ax in axes_flat[n:]:
            ax.axis("off")

        fig.suptitle(f"{ds['name']} — dRM  (ref: {ref_sta})", y=1.02)
        fig.tight_layout()
        plt.show()

    make_grid(ds1)
    make_grid(ds2)
