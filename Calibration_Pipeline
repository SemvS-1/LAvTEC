# PLOTTING dTEC COMPARISON
# =========================================================

def plot_dtec_comparison_grid(
    ds1, ds2, ref_sta,
    # Dataset 1 comparison data
    gnss_stec_1=None, gnss_stations_1=None, gnss_times_mjd_1=None,
    ref_tec_1=None, ref_stations_1=None, ref_times_str_1=None,
    # Dataset 2 comparison data
    gnss_stec_2=None, gnss_stations_2=None, gnss_times_mjd_2=None,
    ref_tec_3d_2=None, ref_stations_2=None, ref_times_str_2=None,
    ref_heights_km_2=None, target_height=350,
    ncols=5,
):
    """
    Grid-layout companion to plot_both_datasets: one figure per dataset
    (ds1, ds2), with a small subplot per station instead of one combined
    plot. Each subplot shows, relative to ref_sta:

      "My data"      -> ds["dTEC"][i]                       (pipeline output, already
                                                                differenced against ref_sta)
      "Old ref"       -> TEC[station] - TEC[ref_sta]           (legacy h5 reference TEC)
      "GNSS old ref"  -> sTEC[station] - sTEC[ref_sta]          (spinifex GNSS sTEC)

    Call this with the exact same arguments you already pass to
    plot_both_datasets (ds1, ds2, ref_sta, plus the gnss_*/ref_* comparison
    data) — it shares the same time_origin-based alignment so the lines land
    on the same hour axis as ds["time"].

    Parameters
    ----------
    ds1, ds2 : dict or None
        Dataset dicts from the main loop. Required keys: 'name', 'stations',
        'time', 'dTEC', 'time_origin'. Either may be None.
    ref_sta : str
        Reference station for this iteration (used for the differencing).
    target_height : float
        Height in km used to slice ref_tec_3d_2 (dataset 2 is height-resolved).
    ncols : int
        Number of subplot columns in the grid.
    """

    # ---- helpers: align comparison times to a pipeline origin (seconds),
    # mirrors plot_both_datasets exactly ----
    def gnss_time_hr(gnss_times_mjd, t0_sec):
        """
        Convert an array of GNSS sample times (MJD) to hours relative to
        the pipeline's RM time origin `t0_sec` (seconds).

        Returns None if either input is missing, so callers can pass
        through absent comparison data without special-casing it.
        """
        if gnss_times_mjd is None or t0_sec is None:
            return None
        return (gnss_times_mjd * 86400.0 - t0_sec) / 3600.0

    def ref_time_hr(ref_times_str, t0_sec):
        """
        Convert an array of ISO-format time strings (legacy reference TEC
        files) to hours relative to the pipeline's RM time origin `t0_sec`
        (seconds).

        Returns None if either input is missing.
        """
        if ref_times_str is None or t0_sec is None:
            return None
        mjd = Time(ref_times_str, format="isot", scale="utc").mjd
        return (mjd * 86400.0 - t0_sec) / 3600.0

    rh_idx_2 = None
    if ref_tec_3d_2 is not None and ref_heights_km_2 is not None:
        rh_idx_2 = np.argmin(np.abs(ref_heights_km_2 - target_height))

    def make_grid(ds, gnss_stec, gnss_stations, gnss_times_mjd,
                  ref_tec, ref_tec_3d, ref_stations, ref_times_str, rh_idx):
        """
        Build and show the per-station dTEC comparison grid for one dataset.

        For each station in `ds`, draws a small subplot overlaying up to
        three curves — the pipeline's own dTEC, the legacy reference TEC
        difference, and the GNSS sTEC difference — all referenced against
        `ref_sta` from the enclosing call and aligned to `ds["time"]` via
        `ds["time_origin"]`. Does nothing if `ds` is None or has no
        stations.

        Parameters
        ----------
        ds : dict or None
            Dataset dict with keys 'name', 'stations', 'time', 'dTEC',
            'time_origin'.
        gnss_stec, gnss_stations, gnss_times_mjd : arrays or None
            GNSS sTEC comparison data for this dataset, as passed to the
            enclosing function (dataset-specific suffix already resolved
            by the caller).
        ref_tec, ref_tec_3d, ref_stations, ref_times_str : arrays or None
            Legacy reference TEC comparison data for this dataset; exactly
            one of ref_tec (2-D) or ref_tec_3d (height-resolved) is
            expected to be non-None.
        rh_idx : int or None
            Height index into ref_tec_3d matching `target_height`, or None
            if ref_tec_3d is not used for this dataset.
        """

        if ds is None:
            return

        t0 = ds["time_origin"]
        time = ds["time"]
        stations = ds["stations"]

        gnss_thr = gnss_time_hr(gnss_times_mjd, t0)
        ref_thr = ref_time_hr(ref_times_str, t0)

        gnss_stations = list(gnss_stations) if gnss_stations is not None else []
        ref_stations = list(ref_stations) if ref_stations is not None else []

        ref_idx_gnss = gnss_stations.index(ref_sta) if ref_sta in gnss_stations else None
        ref_idx_ref = ref_stations.index(ref_sta) if ref_sta in ref_stations else None

        plot_items = list(enumerate(stations))
        n = len(plot_items)
        if n == 0:
            return

        nrows = int(np.ceil(n / ncols))
        fig, axes = plt.subplots(nrows, ncols, figsize=(3.6 * ncols, 2.8 * nrows), squeeze=False, sharex=False, sharey=False)
        axes_flat = axes.flatten()
        legend_handles = {}

        for ax, (i, station) in zip(axes_flat, plot_items):

            # 1) My data ----------------------------------------------------
            if ds["dTEC"] is not None:
                l, = ax.plot(time, ds["dTEC"][i], color="tab:orange", linewidth=1)
                legend_handles.setdefault("My data", l)

            # 2) Old ref (legacy h5, station - ref_sta) ----------------------
            if ref_idx_ref is not None and station in ref_stations and ref_thr is not None:
                s_idx = ref_stations.index(station)

                if ref_tec_3d is not None and rh_idx is not None:
                    diff = ref_tec_3d[s_idx, :, rh_idx] - ref_tec_3d[ref_idx_ref, :, rh_idx]
                elif ref_tec is not None:
                    diff = ref_tec[s_idx] - ref_tec[ref_idx_ref]
                else:
                    diff = None

                if diff is not None:
                    diff_interp = np.interp(time, ref_thr, diff)
                    l, = ax.plot(time, diff_interp, color="tab:green", linewidth=1)
                    legend_handles.setdefault("Old Spinifex", l)

            # 3) GNSS old ref (spinifex sTEC, station - ref_sta) --------------
            if ref_idx_gnss is not None and station in gnss_stations and gnss_thr is not None:
                s_idx = gnss_stations.index(station)
                diff = gnss_stec[s_idx] - gnss_stec[ref_idx_gnss]
                diff_interp = np.interp(time, gnss_thr, diff)

                l, = ax.plot(time, diff_interp, color="tab:blue", linewidth=1)
                legend_handles.setdefault("GNSS Spinifex", l)

            # station label inside the subplot (top-left), not a title
            ax.text(0.04, 0.92, station, transform=ax.transAxes,
                    fontsize=11, va="top", ha="left")

            ax.xaxis.set_major_locator(MaxNLocator(4))
            ax.tick_params(axis="x", labelrotation=45, labelsize=9)
            ax.tick_params(axis="y", labelsize=10)

            col = i % ncols
            row = i // ncols
            if col == 0:
                ax.set_ylabel(r"dTEC [TECU]", fontsize=9)
            if row == nrows - 1 or i >= n - ncols:
                ax.set_xlabel(r"Time [hours]", fontsize=9)
                
        # turn off any unused grid cells
        for ax in axes_flat[n:]:
            ax.axis("off")

        if legend_handles:
            fig.legend(legend_handles.values(), legend_handles.keys(),
                       loc="upper center", ncol=len(legend_handles),
                       bbox_to_anchor=(0.5, 1.02), frameon=False)

        fig.suptitle(f"{ds['name']} — dTEC comparison", y=1.05)
        fig.tight_layout()
        plt.show()

    make_grid(ds1, gnss_stec_1, gnss_stations_1, gnss_times_mjd_1,
              ref_tec_1, None, ref_stations_1, ref_times_str_1, None)
    make_grid(ds2, gnss_stec_2, gnss_stations_2, gnss_times_mjd_2,
              None, ref_tec_3d_2, ref_stations_2, ref_times_str_2, rh_idx_2)
    

