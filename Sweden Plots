def plot_stec(file_path):
    """
    Load GNSS .npz file, compute STEC, and plot per station.

    Parameters
    ----------
    file_path : str or Path
        Path to .npz file containing:
        wtecs, airmass, times, stations
    """

    file_path = Path(file_path)
    data = np.load(file_path)

    # -------------------------
    # Load variables
    # -------------------------
    wtecs = data["wtecs"]
    airmass = data["airmass"]
    times = data["times"]
    stations = list(data["stations"])

    # -------------------------
    # Compute STEC
    # -------------------------
    stec = np.sum(wtecs * airmass, axis=-1)

    print(f"Loaded {file_path.name}")
    print("STEC shape:", stec.shape)

    return stec, stations

