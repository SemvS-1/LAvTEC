def plot_dataset(ds, H=350):

    name = ds["name"]
    time = ds["time"]
    heights = ds["heights"]
    stations = ds["stations"]

    T1 = ds["T1"]
    T2 = ds["T2"]
    B = ds["B"]
    B_ref = ds["B_ref"]

    # --- find 350 km index ---
    h_idx = np.argmin(np.abs(heights - H))
    print(f"{name}: using height = {heights[h_idx]:.1f} km")

    # --- compute dB ---
    dB = B - B_ref[None, :, :]   # (nsta, ntime, nheight)

    # --- extract slices ---
    T1_h = T1[:, :, h_idx]
    T2_h = T2[:, :, h_idx]

    T1dB_h = (T1 * dB)[:, :, h_idx]
    T2dB_h = (T2 * dB)[:, :, h_idx]

    # --- split station indices ---
    rs_idx    = [i for i, s in enumerate(stations) if s.startswith("RS")]
    other_idx = [i for i, s in enumerate(stations) if not s.startswith("RS")]

    # =====================================================
    # PLOTTING
    # =====================================================

    def make_plot(data, title, ylabel, y1=7.5, y2=27.5, station_indices=None, station_labels=None):
        if station_indices is None:
            station_indices = list(range(len(stations)))
        if station_labels is None:
            station_labels = stations

        plt.figure(figsize=(10, 6))

        for i in station_indices:
            plt.plot(time, data[i], label=stations[i], alpha=0.7)

        plt.title(f"{name} — {title} @ {heights[h_idx]:.0f} km")
        plt.xlabel("Time [hr]")
        plt.ylabel(ylabel)

        n = len(station_indices)
        if n <= 10:
            plt.legend()
        else:
            plt.legend(fontsize=6, ncol=2)
        plt.ylim(y1, y2)
        plt.grid(True)
        plt.tight_layout()
        plt.show()

    # --- original plots (all stations) ---
    make_plot(T1_h,    "T1",      "T1")
    make_plot(T2_h,    "T2",      "T2")
    make_plot(T1dB_h,  "T1 × dB", "T1 * dB")
    make_plot(T2dB_h,  "T2 × dB", "T2 * dB")

    # --- RS... stations only ---
    if rs_idx:
        make_plot(T1_h, "T1  [RS stations]",    "T1", station_indices=rs_idx)
        make_plot(T2_h, "T2  [RS stations]",    "T2", station_indices=rs_idx)

    # --- non-RS stations only ---
    if other_idx:
        make_plot(T1_h, "T1  [non-RS stations]", "T1", station_indices=other_idx)
        make_plot(T2_h, "T2  [non-RS stations]", "T2", station_indices=other_idx)

